<Window x:Class="Apteka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apteka"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        
        <!--Header-->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="Resources/icon.png"/>
            <TextBlock Grid.Column="1" Text="Каталог товаров" Style="{StaticResource Title}"></TextBlock>
            <Button Grid.Column="2" Name="btnExit" Content="Назад" Click="btnExit_Click" Style="{StaticResource Buttons}"></Button>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <ListBox Padding="5" Grid.Column="0" Name="LbMedicaments" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="5" BorderBrush="Black" BorderThickness="1">
                         <Grid >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                                <Border Padding="5" Grid.Column="0" BorderBrush="Black" BorderThickness="1">
                                    <Image Source="{Binding Path=PhotoDir}" MaxHeight="100px" MaxWidth="100px"/>
                                </Border>

                                <Border Padding="5" Grid.Column="1" BorderBrush="Black" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Path=MedicationsName.Name}" Style="{StaticResource Title}" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding Path=Description}"/>
                                        <TextBlock Text="{Binding Path=Manufacturers.Name, StringFormat=Производитель: {0}}"/>
                                        <TextBlock Text="{Binding Path=Diagnoses.Name, StringFormat=Диагноз для лечения: {0}}"/>
                                        <TextBlock Text="{Binding Path=FormRealeses.Name, StringFormat=Форма выпуска: {0}}"/>
                                        <TextBlock Text="{Binding Path=CostDisc, StringFormat=Цена: {0}}"/>
                                        <TextBlock Text="{Binding Path=Discount, StringFormat=Скидка: {0}%}"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="5" Grid.Column="2" BorderBrush="Black" BorderThickness="1">
                                    <TextBlock Text="{Binding Path=Count, StringFormat=Количество: {0}}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <!--Filters-->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ФИЛЬТРЫ" Style="{StaticResource Title}"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Сортировка по стоимости" Style="{StaticResource MiniTitle}"/>
                    <RadioButton Name="rbUp" Content="По возрастанию" Checked="rbUp_Checked"/>
                    <RadioButton Name="rbDown" Content="По уменьшению" Checked="rbDown_Checked"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="По категории" Style="{StaticResource MiniTitle}"/>
                    <ComboBox Name="cbCategory" SelectionChanged="cbCategory_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Поиск" Style="{StaticResource MiniTitle}"/>
                    <TextBox Name="tbxSearch" TextChanged="tbxSearch_TextChanged"/>
                </StackPanel>
            </Grid>
        </Grid>
        
    </Grid>
</Window>
