<Window x:Class="Playerok.AddGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Playerok"
        mc:Ignorable="d"
        Title="AddGame" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="6*"/>

        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Resources/icon.png"/>
            <TextBlock Grid.Column="1" FontSize="24" TextAlignment="Center" FontWeight="SemiBold" VerticalAlignment="Center" Text="Добавить игру"/>
            <Button Grid.Column="2" Name="btnBack" Content="Назад" Background="Green" Click="btnBack_Click"/>
        </Grid>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

                        <Border BorderBrush="Black" BorderThickness="2" Padding="15">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Name="tbimgName"/> 
                            <Image Name="imgPrew" MaxHeight="100px" MaxWidth="100px"/>
                            <Button x:Name="btnAdd" Content="Добавить фото" Background="Green" MaxHeight="50" MaxWidth="100"  Click="btnAdd_Click"/>
                        </StackPanel>            
                        </Border>
                                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1">
                                    <StackPanel  Grid.Column="1">
                                <TextBox Text="Наименование" IsReadOnly="True" />
                                <TextBox Name="tbxName"/>
                            <TextBox Text="Жанр"  IsReadOnly="True"/>
                            <ComboBox Name="cbCategory" />
                            <TextBox Text="Разработчик"  IsReadOnly="True"/>
                            <ComboBox Name="cbDeveloper"/>
                            <TextBox Text="Описание"  IsReadOnly="True"/>
                            <TextBox Name="tbxDescription"/>
                            <TextBox Text="Цена"  IsReadOnly="True"/>
                            <TextBox Name="tbxCost"/>
                            <Button x:Name="btnAddGame" Content="Добавить игру" Background="Green" MaxHeight="50" MaxWidth="100"  Click="btnAddGame_Click"/>
                        </StackPanel>
                                </Border>
                                
                            </Grid>
                        </Border>
            
        </Grid>
    </Grid>
</Window>
