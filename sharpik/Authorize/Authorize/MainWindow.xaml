<Window x:Class="Authorize.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Authorize"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>


        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Resources/icon.png"/>
            <TextBlock TextAlignment="Center" VerticalAlignment="Center" Grid.Column="1" FontSize="24" FontWeight="SemiBold" Text="Авторизация"/>
            <Button Grid.Column="2" Name="btnExit" Content="Выход" MaxHeight="50" MaxWidth="100" Background="Green" Click="btnExit_Click"/>

        </Grid>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Введите логин:" FontSize="18" FontWeight="SemiBold"/>
                <Separator Visibility="Hidden" Height="20px"/>
                <TextBlock Text="Введите Пароль:" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBox Name="tbxLogin" MinWidth="200px" FontSize="18" FontWeight="SemiBold"/>
                <Separator Visibility="Hidden" Height="20px"/>
                <PasswordBox Name="tbxPassword" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>

            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Height="50px" Width="200px" Content="Войти" Name="btnIn" Click="btnIn_Click"/>


        </Grid>
        
        
        
    </Grid>
</Window>
